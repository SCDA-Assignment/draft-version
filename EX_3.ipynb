    "@torch.no_grad()\n",
    "def evaluate_error(model, test_points, N_mc=1000, MC_mc=5000):\n",
    "    errors = []\n",
    "    preds = []\n",
    "    truths = []\n",
    "\n",
    "    model.eval()\n",
    "\n",
    "    for t0, x0 in test_points:\n",
